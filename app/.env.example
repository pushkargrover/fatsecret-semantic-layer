# Copy to .env.local and fill in. Never commit real keys.

# The LLM provider is used only for metric SELECTION (never for data access).
LLM_PROVIDER=openai

# OpenAI default.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Optional Anthropic fallback.
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
